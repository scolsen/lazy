(load "Test.carp")
(load "src/lazy.carp")

(use-all Test Lazy)

(deftest test
  (assert-equal test
    3
    (force &(suspend (fn [] (+ 1 2))))
    "force forces evaluation of a lazy computation")
  (assert-equal test
    3
    (do (ignore (force &(suspend (fn [] (+ 1 2)))))
        (force &(suspend (fn [] (+ 1 2)))))
    "multiple applications of force yield the same result")
  (assert-equal test
    0
    (yield &(suspend (fn [] (+ 1 2))))
    "yield returns zero for an unevaluated suspended computation")
  (assert-equal test
    3
    (let [s (suspend (fn [] (+ 1 2)))]
      (do (ignore (force &s))
          (yield &s)))
    "yield returns the memoized value after force")
  (assert-true test
    (= &(suspend (fn [] (+ 1 2))) &(suspend (fn [] (+ 3 4))))
    "= compares unevaluated suspensions without forcing")
  (assert-true test
    (force= &(suspend (fn [] (+ 1 2))) &(suspend (fn [] (+ 1 2))))
    "force= forces and compares suspended computations")
  (assert-false test
    (force= &(suspend (fn [] (+ 1 2))) &(suspend (fn [] (+ 3 4))))
    "force= detects unequal forced values")
  (assert-equal test
    2
    (force &(Lazy.delay mod 2 4))
    "delay promotes the application of a function to a lazy computation")
  (assert-equal test
    2
    (force &(Lazy.lazy (mod 2 4)))
    "lazy promotes an arbitrary form to a lazy computation")
)
